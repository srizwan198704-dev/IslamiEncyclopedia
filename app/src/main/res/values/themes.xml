<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="fontFamily">@font/solaimanlipi</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorSecondaryVariant</item>
        <item name="android:textColorSecondary">@color/purple_500</item>
        <!-- Customize your theme here. -->
        <item name="android:textDirection">ltr</item>
        <item name="android:layoutDirection">ltr</item>
    </style>

        <style name="ToolbarTitleStyle">
            <item name="android:textSize">16sp</item>
            <item name="android:textColor">#FFFFFF</item>
        </style>
    <style name="ToolbarTitleStyle1">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>



    <style name="darkFont">
        <item name="android:fontFamily">@font/solaimanlipi</item>
        <item name="android:textSize">14dp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>
    <style name="lightFont">
        <item name="android:fontFamily">@font/solaimanlipi</item>
        <item name="android:textSize">14dp</item>
        <item name="android:textColor">@color/light_color2</item>
    </style>

    <style name="Widget.App.Switch" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="android:thumbTint">@color/light_color4</item>
        <item name="android:trackTint" tools:ignore="NewApi">@color/light_color6</item>
    </style>

    <style name="Theme.MyApplication.NoActionBar">
        <item name="fontFamily">@font/solaimanlipi</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:textDirection">ltr</item>
        <item name="android:layoutDirection">ltr</item>
    </style>

    <style name="Theme.MyApplication.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="fontFamily">@font/solaimanlipi</item>
        <item name="android:textDirection">ltr</item>
        <item name="android:layoutDirection">ltr</item>
    </style>

    <style name="Theme.MyApplication.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" >
        <item name="fontFamily">@font/solaimanlipi</item>
        <item name="android:textDirection">ltr</item>
        <item name="android:layoutDirection">ltr</item>
    </style>
    <!-- Base application theme. -->
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="fontFamily">@font/solaimanlipi</item>
        <item name="android:textDirection">ltr</item>
        <item name="android:layoutDirection">ltr</item>
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>
</resources>