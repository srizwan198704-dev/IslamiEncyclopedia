<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/toolbar"
		android:layout_width="match_parent"
		android:layout_height="60dp"
		android:paddingLeft="3dp"
		android:paddingTop="1dp"
		android:paddingRight="3dp"
		android:paddingBottom="1dp"
		android:background="#01837A"
		android:gravity="center_vertical"
		android:orientation="horizontal"
		android:elevation="5dp">
		<ImageView
			android:id="@+id/list"
			android:layout_width="40dp"
			android:layout_height="40dp"
			android:layout_marginRight="5dp"
			android:padding="10dp"
			android:src="@drawable/ic_arrow_back_white"
			android:scaleType="fitCenter" />
		<LinearLayout
			android:id="@+id/box"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:gravity="left|center_vertical"
			android:orientation="horizontal">
			<TextView
				android:id="@+id/bookname"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginRight="5dp"
				android:paddingTop="3dp"
				android:gravity="center_vertical"
				android:text="মাদরাসায় দান করুন"
				android:textSize="20sp"
				android:textColor="#FFFFFF"
				android:singleLine="true"
				android:layout_weight="1"
				android:fontFamily="@font/solaimanlipi" />
		</LinearLayout>
	</LinearLayout>
	<ScrollView
		android:id="@+id/vscroll1"
		android:layout_width="match_parent"
		android:layout_height="match_parent">
		<LinearLayout
			android:id="@+id/linear1"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:orientation="vertical">
			<ImageView
				android:id="@+id/imageview1"
				android:layout_width="wrap_content"
				android:layout_height="200dp"
				android:src="@drawable/madrasah"
				android:scaleType="fitCenter" />
			<TextView
				android:id="@+id/textview2"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="➬ ❛মুঝ্ছে মুহাব্বত্ হ্যায় তো মাদ্রাসা কো মুহাব্বত করো, মুঝেহ্ দেখ্না হ্যায় তো মাদ্রাসা কো দেখো।❜ - হযরত সৈয়্যদ আহমদ্ শাহ্ সিরিকোটি (রাহ.)"
				android:textSize="16sp"
				android:textColor="#000000"
				android:fontFamily="@font/solaimanlipi" />
			<TextView
				android:id="@+id/textview1"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="জামেয়া গাউছিয়া তৈয়্যবিয়া তাহেরিয়া মাদ্রাসা। \nবন্দর,নারায়ণগঞ্জ।\n \nপ্রতিষ্ঠাতা- আল্লামা বাকি বিল্লাহ (রহমাতুল্লাহি আলাইহি)\n\nইবতেদায়ী প্রথম শ্রেণী থেকে দশম ও সুন্নী নূরানি + হিফজুল কুরআন বিভাগ। \n\nপরিচালনায়- আনজুমান এ রহমানিয়া আহমদিয়া সুন্নিয়া ট্রাষ্ট - ঢাকা শাখা।\nযোগাযোগের নাম্বার: 01675124184 (দান করার পূর্বে নিশ্চিত হয়ে নিন)"
				android:textSize="18sp"
				android:textColor="#000000"
				android:fontFamily="@font/solaimanlipi" />
			<LinearLayout
				android:id="@+id/mobile"
				android:elevation="5dp"
				android:background="@drawable/back1ground"
				android:layout_margin="10dp"
				android:layout_width="match_parent"
				android:layout_height="200dp"
				android:orientation="vertical">
				<Button
					android:id="@+id/button6"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="যেভাবে সহযোগিতা করতে পারবেন"
					android:textSize="18sp"
					android:textColor="#000000"
					android:fontFamily="@font/solaimanlipi" />
				<LinearLayout
					android:id="@+id/linear7"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="horizontal"
					android:layout_gravity="center_horizontal|center_vertical">
					<ImageView
						android:id="@+id/imageview2"
						android:layout_width="50dp"
						android:layout_height="50dp"
						android:src="@drawable/bkash"
						android:scaleType="fitXY" />
					<LinearLayout
						android:id="@+id/linear8"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:orientation="vertical">
						<TextView
							android:id="@+id/textview5"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:gravity="center_horizontal|center_vertical"
							android:text="বিকাশ একাউন্ট"
							android:textSize="16sp"
							android:textColor="#E91E63"
							android:layout_gravity="center_horizontal|center_vertical"
							android:fontFamily="@font/solaimanlipi" />
						<LinearLayout
							android:id="@+id/linear9"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:orientation="horizontal">
							<TextView
								android:id="@+id/textview6"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:padding="8dp"
								android:gravity="center_horizontal|center_vertical"
								android:text="+8801813266481 (Personal)"
								android:textSize="16sp"
								android:textColor="#4CAF50"
								android:layout_gravity="center_horizontal|center_vertical"
								android:fontFamily="@font/solaimanlipi" />
						</LinearLayout>
					</LinearLayout>
				</LinearLayout>
			</LinearLayout>
		</LinearLayout>
	</ScrollView>
</LinearLayout>
