<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="20dp">

    <!-- Dialog Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_report"
            android:contentDescription="Report Icon" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Report Issue"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1E1E1E" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Describe your issue:"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/editText"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:hint="Write your problem details here..."
        android:gravity="top"
        android:inputType="textMultiLine"
        android:background="@drawable/bg_edittext"
        android:padding="12dp"
        android:textSize="14sp"
        android:textColor="#01837A"
        android:maxLines="5"
        android:scrollbars="vertical"
        android:layout_marginBottom="20dp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:rowCount="2"
        android:columnCount="2"
        android:useDefaultMargins="true">

        <Button
            android:id="@+id/sendButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:text="Direct send"
            android:background="@drawable/bg_button_telegram"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:drawableStart="@drawable/ic_telegram"
            android:drawablePadding="8dp" />

        <Button
            android:id="@+id/emailButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:text="Email"
            android:background="@drawable/bg_button_email"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:drawableStart="@drawable/ic_email"
            android:drawablePadding="8dp" />

        <Button
            android:id="@+id/whatsapp"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:text="WhatsApp"
            android:background="@drawable/bg_button_whatsapp"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:drawableStart="@drawable/ic_whatsapp"
            android:drawablePadding="8dp" />

        <Button
            android:id="@+id/telegramButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:text="Telegram"
            android:background="@drawable/bg_button_telegram_direct"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:visibility="gone"
            android:drawableStart="@drawable/ic_telegram_direct"
            android:drawablePadding="8dp" />

    </GridLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Tap outside to close"
        android:textSize="11sp"
        android:textColor="#999999"
        android:layout_gravity="center" />

</LinearLayout>
