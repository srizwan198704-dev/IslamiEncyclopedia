<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="@color/white"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/linear1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:elevation="4dp"
        tools:ignore="MissingConstraints"
        android:layout_marginTop="10dp">

        <LinearLayout
            android:id="@+id/linear4"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="5dp">

            <LinearLayout
                android:id="@+id/linear11"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/ic_1_4"
                android:gravity="center">

                <TextView
                    android:id="@+id/number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100"
                    android:textColor="#607D8B"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/linear5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="0"
                android:orientation="horizontal" />
            <ImageView
                android:id="@+id/playme"
                android:focusable="false"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:padding="5dp"
                android:src="@drawable/play_circle"
                android:scaleType="fitCenter" />
            <ImageView
                android:id="@+id/shareme"
                android:focusable="false"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:padding="5dp"
                android:src="@drawable/share_round"
                android:scaleType="fitCenter" />
            <ImageView
                android:id="@+id/copyme"
                android:focusable="false"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:padding="5dp"
                android:rotation="180"
                android:scaleX="-1"
                android:src="@drawable/content_copy"
                android:scaleType="fitCenter" />
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/linear3"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/baseline_content_copy_24"
                android:padding="8dp"
                android:gravity="center_vertical" />
        </LinearLayout>

        <TextView
            android:id="@+id/ayaarabic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:gravity="right"
            android:text="بِسْمِ  اللَّهِ الرَّحْمَنِ الرَّحِيم"
            android:textColor="#000000"
            android:textSize="28sp"
            android:textDirection="rtl"
            android:layoutDirection="rtl"
            android:fontFamily="@font/noorehuda"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/kanzul"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:background="#E0F2F1"
            android:padding="8dp"
            android:text="কানযুল ঈমান"
            android:textColor="#009688"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="আল্লাহর নামে আরম্ভ যিনি পরম দয়ালু, করুণাময়"
            android:textColor="#000000"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/irfan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:background="#E3F2FD"
            android:padding="8dp"
            android:text="ইরফানুল কুরআন"
            android:textColor="#1E88E5"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ayanumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="আল্লাহর নামে শুরু, যিনি পরম করুণাময়, সতত অসীম দয়ালু।"
            android:textColor="#000000"
            android:textSize="16sp" />
    </LinearLayout>
</LinearLayout>
