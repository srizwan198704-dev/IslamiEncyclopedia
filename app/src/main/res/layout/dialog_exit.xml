<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:elevation="6dp"
    android:id="@+id/cardView"
    android:layout_margin="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/edit"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="আসসালামু আলাইকুম! আপনি কি বের হতে চান?"
            android:textSize="18sp"
            android:textColor="#757575"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="এই অ্যাপটি সদকায়ে জারিয়ার নিয়্যতে প্রচার করুন। ইনশাআল্লাহ আরো নতুন নতুন বই যুক্ত হবে।"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginTop="10dp"
            android:gravity="center"/>
        <Button
            android:id="@+id/rate1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:text="রেটিং দিন"/>
        <Button
            android:id="@+id/share1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:text="শেয়ার করুন"/>

        <Button
            android:id="@+id/finishaffinity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:text="হ্যাঁ, অ্যাপটি বন্ধ করুন"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
