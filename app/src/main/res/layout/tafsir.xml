<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:background="@drawable/back1ground"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<ScrollView
		android:id="@+id/vscrollmain"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_margin="10dp"
		android:background="#FFFFFF">
		<LinearLayout
			android:id="@+id/main"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="5dp"
			android:orientation="vertical"
			android:elevation="4dp">
			<LinearLayout
				android:id="@+id/linear2"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal">
				<LinearLayout
					android:id="@+id/linear3"
					android:layout_width="50dp"
					android:layout_height="50dp"
					android:padding="8dp"
					android:background="@drawable/ic_1_4"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="horizontal"
					android:layout_gravity="center_horizontal|center_vertical">
					<TextView
						android:id="@+id/number"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:textSize="10sp"
						android:textColor="#000000"
						android:focusable="false"
						android:fontFamily="@font/solaimanlipi" />
				</LinearLayout>
			</LinearLayout>
			<TextView
				android:id="@+id/ayaarabic"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="right"
				android:textSize="20sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:layout_gravity="right"
				android:focusable="false"
				android:textDirection="rtl"
				android:layoutDirection="rtl"
				android:fontFamily="@font/bold" />
			<TextView
				android:id="@+id/words"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:focusable="false"
				android:fontFamily="@font/solaimanlipi" />
			<LinearLayout
				android:id="@+id/maintafsiribnabbas"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				android:orientation="vertical">
				<TextView
					android:id="@+id/headingtafsiribnabbas"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#E8F5E9"
					android:text="তাফসিরে ইবনে আব্বাস (رضي الله عنه)"
					android:textSize="14sp"
					android:textColor="#4CAF50"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
				<TextView
					android:id="@+id/texttafsiribnabbas"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:layout_marginTop="5dp"
					android:padding="8dp"
					android:textSize="16sp"
					android:textColor="#000000"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/mainkanzulimaanlayout"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				android:orientation="vertical">
				<TextView
					android:id="@+id/headingkanzulimaan"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#E0F2F1"
					android:text="কানযুল ঈমান"
					android:textSize="14sp"
					android:textColor="#009688"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
				<TextView
					android:id="@+id/textkanzuliman"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:layout_marginTop="5dp"
					android:padding="8dp"
					android:textSize="16sp"
					android:textColor="#000000"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/mainkhazainulirfan"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				android:orientation="vertical">
				<TextView
					android:id="@+id/headingkhazainulirfan"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#E0F7FA"
					android:text="তাফসিরে খাযাইনুল ইরফান"
					android:textSize="14sp"
					android:textColor="#00BCD4"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
				<TextView
					android:id="@+id/texttafsirkhazainulirfan"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:layout_marginTop="5dp"
					android:padding="8dp"
					android:textSize="16sp"
					android:textColor="#000000"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/maintafsirnurulirfan"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				android:orientation="vertical">
				<TextView
					android:id="@+id/headingtafsirnurulirfan"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#E3F2FD"
					android:text="তাফসিরে নুরুল ইরফান"
					android:textSize="14sp"
					android:textColor="#1E88E5"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
				<TextView
					android:id="@+id/texttafsirnurulirfan"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:layout_marginTop="5dp"
					android:padding="8dp"
					android:textSize="16sp"
					android:textColor="#000000"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/mainirfanullayout"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				android:orientation="vertical">
				<TextView
					android:id="@+id/headingirfanulkuran"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#FBE9E7"
					android:text="ইরফানুল কুরআন"
					android:textSize="14sp"
					android:textColor="#FF5722"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
				<TextView
					android:id="@+id/textifranulkuran"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:layout_marginTop="5dp"
					android:padding="8dp"
					android:textSize="16sp"
					android:textColor="#000000"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/maintafsirtabari"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				android:orientation="vertical">
				<TextView
					android:id="@+id/headingtafsirtabari"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#F3E5F5"
					android:text="তাফসিরে তাবারী"
					android:textSize="14sp"
					android:textColor="#9C27B0"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
				<TextView
					android:id="@+id/texttafsirtabari"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:layout_marginTop="5dp"
					android:padding="8dp"
					android:textSize="16sp"
					android:textColor="#000000"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/maintafsirmajhari"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				android:orientation="vertical">
				<TextView
					android:id="@+id/headingtafsirmajhari"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#FCE4EC"
					android:text="তাফসিরে মাযহারী"
					android:textSize="14sp"
					android:textColor="#E91E63"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
				<TextView
					android:id="@+id/texttafsirmajhari"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:layout_marginTop="5dp"
					android:padding="8dp"
					android:textSize="16sp"
					android:textColor="#000000"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/maintafsiribnkasir"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				android:orientation="vertical">
				<TextView
					android:id="@+id/headingtafsiribnkasir"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#FFEBEE"
					android:text="তাফসিরে ইবনে কাছীর"
					android:textSize="14sp"
					android:textColor="#F44336"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
				<TextView
					android:id="@+id/texttafsiribnkasir"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:layout_marginTop="5dp"
					android:padding="8dp"
					android:textSize="16sp"
					android:textColor="#000000"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/maintafsirkurtubi"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				android:orientation="vertical">
				<TextView
					android:id="@+id/headingtafsirkurtubi"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#ECEFF1"
					android:text="তাফসিরে কুরতবী"
					android:textSize="14sp"
					android:textColor="#607D8B"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
				<TextView
					android:id="@+id/texttafsirkurtubi"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:layout_marginTop="5dp"
					android:padding="8dp"
					android:textSize="16sp"
					android:textColor="#000000"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/maintafsirbaizabi"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				android:orientation="vertical">
				<TextView
					android:id="@+id/headingtafsirbaizabi"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#F1F8E9"
					android:text="তাফসিরে বায়যাবী"
					android:textSize="14sp"
					android:textColor="#8BC34A"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
				<TextView
					android:id="@+id/texttafsirbaizabi"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:layout_marginTop="5dp"
					android:padding="8dp"
					android:textSize="16sp"
					android:textColor="#000000"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/maintafsirrezbiya"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				android:orientation="vertical">
				<TextView
					android:id="@+id/headingtafsirrezbiya"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#EFEBE9"
					android:text="তাফসিরে রেজভীয়া"
					android:textSize="14sp"
					android:textColor="#795548"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
				<TextView
					android:id="@+id/texttafsirrezviya"
					android:layout_width="wrap_content"
					android:layout_height="match_parent"
					android:layout_marginTop="5dp"
					android:padding="8dp"
					android:textSize="16sp"
					android:textColor="#000000"
					android:focusable="false"
					android:fontFamily="@font/solaimanlipi" />
			</LinearLayout>
		</LinearLayout>
	</ScrollView>
</LinearLayout>
