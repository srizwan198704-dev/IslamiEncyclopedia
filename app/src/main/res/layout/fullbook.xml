<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/white"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/main"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="@color/white"
		android:orientation="vertical">
		<LinearLayout
			android:id="@+id/sub"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="#01837A"
			android:gravity="center_vertical"
			android:orientation="horizontal"
			android:elevation="5dp">
			<TextView
				android:id="@+id/name"
				android:focusable="false"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:gravity="center_vertical"
				android:textSize="18sp"
				android:textColor="#FFFFFF"
				android:layout_weight="1"
				android:fontFamily="@font/solaimanlipi" />
		</LinearLayout>
		<ScrollView
			android:id="@+id/vscroll1"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:layout_weight="1">
			<LinearLayout
				android:id="@+id/container"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:orientation="vertical">
				<TextView
					android:id="@+id/author"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginLeft="5dp"
					android:layout_marginTop="5dp"
					android:layout_marginRight="5dp"
					android:layout_marginBottom="10dp"
					android:padding="8dp"
					android:textSize="16sp"
					android:textColor="#000000"
					android:fontFamily="@font/solaimanlipi" />
			</LinearLayout>
		</ScrollView>
		<LinearLayout
			android:id="@+id/Tab"
			android:layout_width="match_parent"
			android:layout_height="50dp"
			android:background="#01837A"
			android:gravity="center_vertical"
			android:orientation="horizontal">
			<LinearLayout
				android:id="@+id/back"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal"
				android:layout_weight="1">
				<ImageView
					android:id="@+id/imageview1"
					android:focusable="false"
					android:layout_width="56dp"
					android:layout_height="56dp"
					android:padding="15dp"
					android:src="@drawable/ic_arrow_back_white"
					android:scaleType="fitCenter" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/share"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal"
				android:layout_gravity="center_horizontal|center_vertical"
				android:layout_weight="1">
				<ImageView
					android:id="@+id/imageview2"
					android:focusable="false"
					android:layout_width="56dp"
					android:layout_height="56dp"
					android:padding="15dp"
					android:src="@drawable/ic_share_white"
					android:scaleType="fitCenter" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/copy"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal"
				android:layout_weight="1">
				<ImageView
					android:id="@+id/imageview3"
					android:focusable="false"
					android:layout_width="56dp"
					android:layout_height="56dp"
					android:padding="15dp"
					android:src="@drawable/ic_content_copy_white"
					android:scaleType="fitCenter" />
			</LinearLayout>
			<TextView
				android:id="@+id/textview3"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:background="@android:color/transparent"
				android:gravity="right"
				android:text="ফন্ট"
				android:textSize="16sp"
				android:textColor="#FFFFFF"
				android:fontFamily="@font/solaimanlipi" />
			<LinearLayout
				android:id="@+id/high"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal"
				android:layout_weight="1">
				<ImageView
					android:id="@+id/imageview4"
					android:focusable="false"
					android:layout_width="56dp"
					android:layout_height="56dp"
					android:padding="15dp"
					android:src="@drawable/ic_keyboard_arrow_up_white"
					android:scaleType="fitCenter" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/low"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:layout_marginLeft="10dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal"
				android:layout_weight="1">
				<ImageView
					android:id="@+id/imageview5"
					android:focusable="false"
					android:layout_width="56dp"
					android:layout_height="56dp"
					android:padding="15dp"
					android:src="@drawable/ic_keyboard_arrow_up_white"
					android:scaleType="fitCenter"
					android:rotation="180" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/next"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:layout_marginLeft="10dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal"
				android:layout_weight="1">
				<ImageView
					android:id="@+id/imageview6"
					android:focusable="false"
					android:layout_width="56dp"
					android:layout_height="56dp"
					android:padding="15dp"
					android:src="@drawable/ic_arrow_back_white"
					android:scaleType="fitCenter"
					android:rotation="180" />
			</LinearLayout>
		</LinearLayout>
	</LinearLayout>
	<LinearLayout
		android:id="@+id/hideview"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="#E0F2F1"
		android:gravity="center_vertical"
		android:orientation="vertical"
		android:layout_gravity="center_vertical">
		<TextView
			android:id="@+id/hide"
			android:focusable="false"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:layout_margin="2dp"
			android:gravity="center_horizontal|center_vertical"
			android:textSize="25sp"
			android:textColor="#000000"
			android:layout_gravity="center_vertical"
			android:layout_weight="1"
			android:fontFamily="@font/solaimanlipi" />
		<LinearLayout
			android:id="@+id/book"
			android:layout_width="match_parent"
			android:layout_height="50dp"
			android:layout_marginBottom="5dp"
			android:background="@android:color/transparent"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal"
			android:layout_gravity="center_horizontal|center_vertical">
			<LinearLayout
				android:id="@+id/bookback"
				android:layout_width="50dp"
				android:layout_height="match_parent"
				android:layout_marginLeft="10dp"
				android:background="#01837A"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal">
				<ImageView
					android:id="@+id/imageview9"
					android:focusable="false"
					android:layout_width="56dp"
					android:layout_height="56dp"
					android:padding="15dp"
					android:src="@drawable/ic_arrow_back_white"
					android:scaleType="fitCenter" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear20"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:orientation="horizontal"
				android:layout_weight="1" />
			<LinearLayout
				android:id="@+id/booknext0"
				android:layout_width="50dp"
				android:layout_height="match_parent"
				android:layout_marginRight="10dp"
				android:background="#01837A"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal">
				<ImageView
					android:id="@+id/imageview14"
					android:focusable="false"
					android:layout_width="56dp"
					android:layout_height="56dp"
					android:padding="15dp"
					android:src="@drawable/ic_arrow_back_white"
					android:scaleType="fitCenter"
					android:rotation="180" />
			</LinearLayout>
		</LinearLayout>
	</LinearLayout>
</LinearLayout>
