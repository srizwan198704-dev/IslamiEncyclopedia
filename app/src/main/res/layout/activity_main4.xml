<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:fitsSystemWindows="true"
    android:background="@drawable/back1ground"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Main4Activity">

    <!-- টপ বারের লেআউট -->
    <LinearLayout
        android:id="@+id/linear1"
        android:elevation="5dp"
        android:gravity="center_vertical"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:background="@color/teal_200"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_arrow_back_white"
            android:scaleType="centerCrop"
            android:padding="15dp"
            android:id="@+id/back"/>

        <TextView
            android:id="@+id/heading1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/solaimanlipi"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:scrollHorizontally="true"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:singleLine="true"
            android:text="@string/app_name"
            android:layout_marginLeft="5dp"
            android:gravity="center_vertical"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>
        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginRight="10dp"
            android:src="@drawable/ic_jump_page"
            android:scaleType="fitCenter"
            android:id="@+id/jump"/>
        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginRight="5dp"
            android:src="@drawable/searchme"
            android:scaleType="fitCenter"
            android:id="@+id/searchme"/>

    </LinearLayout>

    <!-- Search Bar Layout -->
    <LinearLayout
        android:id="@+id/searchView"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/linear1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/boxofsearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:layout_weight="1"
            app:hintTextColor="@color/purple_500"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <EditText
                android:id="@+id/searchbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/solaimanlipi"
                android:padding="8dp"
                android:textColor="#000000"
                android:textColorHint="@color/purple_500"
                android:textSize="14sp"
                tools:ignore="TouchTargetSizeCheck" />
        </com.google.android.material.textfield.TextInputLayout>

        <ImageView
            android:id="@+id/cancelme"
            android:layout_width="30dp"
            android:layout_height="match_parent"
            android:layout_marginRight="5dp"
            android:src="@drawable/cancel"
            android:scaleType="fitCenter"/>
    </LinearLayout>

    <!-- Author & Subject filter -->
    <LinearLayout
        android:id="@+id/select"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/searchView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/boxofauthor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:layout_weight="1"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <EditText
                android:id="@+id/searchboxauthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/solaimanlipi"
                android:padding="8dp"
                android:textColor="#000000"
                android:textColorHint="#607D8B"
                android:textSize="14sp"
                android:text="সকল লেখক"
                android:gravity="center"
                tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/boxofsubject"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:layout_weight="1"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <EditText
                android:id="@+id/searchboxsubject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/solaimanlipi"
                android:padding="8dp"
                android:textColor="#000000"
                android:textColorHint="#607D8B"
                android:textSize="14sp"
                android:text="সকল বিষয়"
                android:gravity="center"
                tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/nores"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/select"
        app:layout_constraintBottom_toTopOf="@id/listview1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#FFFFFF"
        android:gravity="center_horizontal|center_vertical"
        android:orientation="vertical"
        android:layout_gravity="center_horizontal|center_vertical">
        <ImageView
            android:id="@+id/noresult"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/noresult"
            android:scaleType="fitCenter"
            android:layout_gravity="center_horizontal|center_vertical" />
        <TextView
            android:id="@+id/no_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:gravity="center_horizontal|center_vertical"
            android:text="কোন সার্চ রেজাল্ট পাওয়া যায়নি"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_gravity="center_horizontal|center_vertical"
            android:fontFamily="@font/solaimanlipi" />
    </LinearLayout>
    <!-- ListView -->
    <ListView
        android:id="@+id/listview1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:background="@color/white"
        android:listSelector="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/nores"
        app:layout_constraintBottom_toTopOf="@id/audiotab"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Audio control -->
    <LinearLayout
        android:id="@+id/audiotab"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:background="#01837A"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/previous"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:padding="8dp"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/previous_image"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/previous"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/between0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="8dp"
            android:orientation="horizontal" />

        <LinearLayout
            android:id="@+id/playAudio1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/playAudio"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/play"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/between1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="8dp"
            android:orientation="horizontal" />

        <LinearLayout
            android:id="@+id/next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/next_image"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/previous"
                android:scaleType="fitCenter"
                android:rotation="180" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/between2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="8dp"
            android:orientation="horizontal" />

        <LinearLayout
            android:id="@+id/stop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="10dp"
            android:padding="8dp"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/stop_image"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/stop"
                android:scaleType="fitCenter" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
