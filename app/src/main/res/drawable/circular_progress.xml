<?xml version="1.0" encoding="utf-8" ?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android" android:fromDegrees="120.0" android:toDegrees="140.0" android:pivotX="50.0%" android:pivotY="50.0%">
